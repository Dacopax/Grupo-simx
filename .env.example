# ============================================
# Configuración del Servidor GrupoSimx
# ============================================

# Puerto del servidor (solo desarrollo local)
PORT=3000

# ============================================
# Google Analytics 4
# ============================================
# Obtén tu ID de medición en: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# Google Tag Manager
# ============================================
# Obtén tu ID de contenedor en: https://tagmanager.google.com/
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ============================================
# Formulario de Contacto
# ============================================
# Opcional: Configurar EmailJS para envío de emails
# EMAILJS_SERVICE_ID=
# EMAILJS_TEMPLATE_ID=
# EMAILJS_PUBLIC_KEY=

# Opcional: Configurar Formspree para envío de formularios
# FORMSPREE_ENDPOINT=

# Opcional: Notificación WhatsApp
# WHATSAPP_NOTIFICATION_NUMBER=

# ============================================
# API Base (solo si se usa backend externo)
# ============================================
# NEXT_PUBLIC_API_BASE=
